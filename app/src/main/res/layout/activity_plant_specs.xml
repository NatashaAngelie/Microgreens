<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_muted">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPlantSpecs"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        app:navigationIcon="@drawable/ic_back_24"
        app:navigationIconTint="@color/white"
        app:title="Plant Specifications"
        app:titleTextColor="@color/white" />

    <!-- 0dp + weight: di LinearLayout vertikal, match_parent untuk RecyclerView sering bikin area scroll salah / item kepotong. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlantSpecs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:scrollbars="vertical" />

</LinearLayout>

