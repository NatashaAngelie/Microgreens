<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_marginBottom="16dp"
    android:background="@android:color/white">

    <!-- Plant Name -->
    <TextView
        android:id="@+id/plantName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Radish Microgreens"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Plant Info -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Planted"/>

        <TextView
            android:id="@+id/datePlanted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Sprouted"/>

        <TextView
            android:id="@+id/dateSprouted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not yet"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Harvested"/>

        <TextView
            android:id="@+id/dateHarvested"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not yet"/>
    </LinearLayout>


    <!-- Divider -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>


    <!-- Last Watered -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Last Watered"/>

        <TextView
            android:id="@+id/lastWatered"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"/>
    </LinearLayout>


    <!-- Lamp Status -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Lamp Status"/>

        <TextView
            android:id="@+id/lampStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFF"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Lamp Changed"/>

        <TextView
            android:id="@+id/lampChanged"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"/>
    </LinearLayout>


    <!-- Fan Status -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Fan Status"/>

        <TextView
            android:id="@+id/fanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFF"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="Fan Changed"/>

        <TextView
            android:id="@+id/fanChanged"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"/>
    </LinearLayout>

</LinearLayout>